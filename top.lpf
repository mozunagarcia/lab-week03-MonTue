LOCATE COMP "clk" SITE "P6";
IOBUF PORT "clk" IO_TYPE=LVCMOS33;
FREQUENCY PORT "clk" 25 MHZ;

# Buttons (PMOD 4)
LOCATE COMP "btn1" SITE "C4";
IOBUF PORT "btn1" IO_TYPE=LVCMOS33;

LOCATE COMP "btn2" SITE "C3";
IOBUF PORT "btn2" IO_TYPE=LVCMOS33;

# DIP Switches (PMOD 4) — sw[0]=SW1 ... sw[3]=SW4
LOCATE COMP "sw[0]" SITE "H3";
IOBUF PORT "sw[0]" IO_TYPE=LVCMOS33;

LOCATE COMP "sw[1]" SITE "J3";
IOBUF PORT "sw[1]" IO_TYPE=LVCMOS33;

LOCATE COMP "sw[2]" SITE "J2";
IOBUF PORT "sw[2]" IO_TYPE=LVCMOS33;

LOCATE COMP "sw[3]" SITE "K3";
IOBUF PORT "sw[3]" IO_TYPE=LVCMOS33;

# 7-Segment Display (PMOD 5) — seg[0]=a, seg[1]=b, ... seg[6]=g
LOCATE COMP "seg[0]" SITE "C7";
IOBUF PORT "seg[0]" IO_TYPE=LVCMOS33;

LOCATE COMP "seg[1]" SITE "C8";
IOBUF PORT "seg[1]" IO_TYPE=LVCMOS33;

LOCATE COMP "seg[2]" SITE "D8";
IOBUF PORT "seg[2]" IO_TYPE=LVCMOS33;

LOCATE COMP "seg[3]" SITE "D7";
IOBUF PORT "seg[3]" IO_TYPE=LVCMOS33;

LOCATE COMP "seg[4]" SITE "D6";
IOBUF PORT "seg[4]" IO_TYPE=LVCMOS33;

LOCATE COMP "seg[5]" SITE "C6";
IOBUF PORT "seg[5]" IO_TYPE=LVCMOS33;

LOCATE COMP "seg[6]" SITE "C5";
IOBUF PORT "seg[6]" IO_TYPE=LVCMOS33;

LOCATE COMP "dp" SITE "D9";
IOBUF PORT "dp" IO_TYPE=LVCMOS33;

# On-board RGB LED (active-low)
LOCATE COMP "led_r" SITE "B11";
IOBUF PORT "led_r" IO_TYPE=LVCMOS33;

LOCATE COMP "led_g" SITE "A11";
IOBUF PORT "led_g" IO_TYPE=LVCMOS33;

LOCATE COMP "led_b" SITE "A12";
IOBUF PORT "led_b" IO_TYPE=LVCMOS33;
